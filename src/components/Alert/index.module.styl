@import '../../styles/mixin.styl'
@import '../../styles/variable.styl'

.alert-container
  padding 6PX $WING_BLANK
  position relative
  box-sizing border-box
  width 100%
  display flex
  flex-direction column
  overflow hidden

  &.is-pressable
    &:active
      opacity 0.7

  &.show-animation
    animation alertFadeIn 0.3s ease-out forwards

    &.is-leaving
      animation alertFadeOut 0.25s ease-in forwards

.alert-content
  display flex
  flex-direction row

.icon-wrapper
  margin-right 8PX
  flex-shrink 0
  display flex
  align-items center
  justify-content center

.text-container
  flex 1
  display flex
  flex-direction column
  overflow hidden

.message-text
  getPlatformFontSize(13)
  line-height 20PX
  word-break break-word
  white-space pre-line

.scroll-text
  getPlatformFontSize(13)
  line-height 20PX
  white-space nowrap
  padding-right 60PX

.scroll-wrapper
  overflow hidden
  width 100%

.scroll-track
  display flex
  width max-content
  align-items center
  animation alertScroll 18s linear infinite
  will-change transform

.description-wrapper
  margin-top 4PX

.description-text
  getPlatformFontSize(12)
  line-height 18PX

.action-container
  margin-left 8PX
  display flex
  flex-direction row
  align-items center

.close-btn-wrapper
  display flex
  align-items center
  justify-content center

.close-text
  getPlatformFontSize(12)


@keyframes alertFadeIn
  0%
    opacity 0
    transform translateY(-20PX)
  100%
    opacity 1
    transform translateY(0)

@keyframes alertFadeOut
  0%
    opacity 1
    transform translateY(0)
  100%
    opacity 0
    transform translateY(-20PX)

@keyframes alertScroll
  0%
    transform translate3d(0,0,0)
  100%
    transform translate3d(-50%,0,0)
