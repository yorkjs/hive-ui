@import '../../styles/mixin.styl'

.entry-item-card
  padding 14PX 18PX
  position relative

.card-main-body
  display flex
  flex-direction row
  align-items center
  justify-content space-between

.card-icon-section
  flex-shrink 0
  margin-right 12PX
  display flex
  align-items center
  justify-content center

  .menu-icon
    width 44PX
    height 44PX

.card-info
  flex 1
  display flex
  flex-direction column
  overflow hidden

  .card-title
    font-size 15PX
    color var(--textTitle)
    line-height 21PX
    margin-bottom 3PX
    wordBreak()

  .card-desc
    font-size 13PX
    color var(--textMuted)
    line-height 19PX
    lineClamp(2)
    wordBreak()

.card-right-section
  margin-left 10PX
  flex-shrink 0
  display flex
  align-items center

  .arrow-icon
    font-size 14PX