@import '../../styles/mixin.styl'
@import '../../styles/variable.styl'

$CELL_PADDING_VERTICAL = 14PX

.field-card-container
  border-radius 10PX
  background-color var(--containerCard)
  overflow hidden

.card-head-wrapper
  padding 0PX $CELL_PADDING_VERTICAL

.card-header
  display flex
  flex-direction row
  align-items center
  justify-content space-between
  padding 13PX 0PX
  position relative
  halfBorder(bottom, var(--lineBorder))

  .header-left
    flex 1
    display flex
    flex-direction row
    align-items center
    min-width 0

    .header-title
      color var(--textTitle)
      font-size 14PX
      line-height 1
      lineClamp(1)

    .edit-icon-wrapper
      margin-left 2PX
      display flex
      align-items center
      justify-content center
      border-radius 4PX
      transition background-color 0.2s

      &:active
        background-color rgba(0, 0, 0, 0.05)

      .edit-icon
        color var(--textMuted)

  .header-extra
    margin-left 12PX
    flex-shrink 0
    display flex
    align-items center

    .action-text
      color var(--primary)
      font-size 13PX
      &:active
        opacity 0.6