@import '../../styles/mixin.styl'

$saas_padding = 15PX

.list-item-card
  padding $saas_padding
  padding-bottom 0
  position relative

.card-main-body
  display flex
  flex-direction row
  justify-content space-between
  align-items flex-start
  padding-bottom $saas_padding

  &.show-separator
    halfBorder(bottom, var(--lineBorder))

  &.no-footer
    padding-bottom $saas_padding

.card-info
  flex 1
  display flex
  flex-direction column
  min-width 0

.card-title
  font-size 16PX
  color var(--textTitle)
  line-height 23PX
  margin-bottom 9PX
  wordBreak()

.card-text-line
  font-size 14PX
  color var(--textTitle)
  line-height 20PX
  wordBreak()
  & + .card-text-line
    margin-top 6PX

.card-right-section
  margin-left 10PX
  flex-shrink 0
  display flex
  flex-direction row
  align-items center

  .extra-wrapper
    display flex
    align-items center

  .internal-arrow
    margin-left 10PX
    flex-shrink 0

.card-footer
  width 100%